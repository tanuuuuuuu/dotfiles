# gswitch-setup - gcloud プロファイル作成ヘルパー
# source で読み込む関数ファイル
#
# プロファイル = ~/.config/gcloud-profiles/<name>/ に隔離された gcloud 設定ディレクトリ。
# config・認証情報・ADC がすべてプロファイル内で完結するため、
# プロファイル内で再ログインしても他のプロファイルに影響しない。
#
# 切り替えは direnv に任せる。リポジトリの .envrc に:
#   export CLOUDSDK_CONFIG="$HOME/.config/gcloud-profiles/<name>"
# 同じアカウントで project だけ変えたい場合はプロファイルを増やさず:
#   export CLOUDSDK_CORE_PROJECT="<project-id>"

GSWITCH_PROFILES_DIR="$HOME/.config/gcloud-profiles"

gswitch-setup() {
  local name="$1"
  local account="$2"
  local project="$3"

  if [ -z "$name" ] || [ -z "$account" ] || [ -z "$project" ]; then
    echo "使い方: gswitch-setup <プロファイル名> <account> <project>"
    echo ""
    echo "例: gswitch-setup work user@company.com my-project-123"
    return 1
  fi

  local dir="$GSWITCH_PROFILES_DIR/$name"
  if [ -d "$dir" ]; then
    echo "エラー: プロファイル '$name' は既に存在します"
    return 1
  fi

  echo "=== プロファイル '$name' を作成します ==="
  echo "  account: $account"
  echo "  project: $project"
  echo ""

  mkdir -p "$dir"
  (
    export CLOUDSDK_CONFIG="$dir"
    gcloud config set account "$account"
    gcloud config set project "$project"

    # 認証（ブラウザが開く）
    echo ""
    echo "--- gcloud CLI 認証 ---"
    gcloud auth login "$account"

    echo ""
    echo "--- ADC 認証 ---"
    gcloud auth application-default login
  )

  echo ""
  echo "セットアップ完了。リポジトリの .envrc に以下を追加して direnv allow:"
  echo "  export CLOUDSDK_CONFIG=\"$dir\""
}
